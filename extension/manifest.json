{
  "manifest_version": 3,
  "name": "Autofill Assistant",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "webNavigation", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
